# Local runtime
APP_ENVIRONMENT=DEV
GATEWAY_SPRING_PROFILES_ACTIVE=dev
RESERVA_SPRING_PROFILES_ACTIVE=docker,dev
QUARTO_SPRING_PROFILES_ACTIVE=dev
USERS_SPRING_PROFILES_ACTIVE=dev
PAGAMENTO_SPRING_PROFILES_ACTIVE=dev

# Render web services
# Render injects PORT automatically in many cases, but the project uses this
# value explicitly to make Spring Boot and Grafana bind to the port Render scans.
PORT=10000
SERVER_PORT=10000

# JWT - replace in real environments
JWT_SECRET=change-me-with-a-long-random-secret
JWT_ISSUER=hosped-users
JWT_EXPIRATION=28800000

# Local service URLs
USERS_SERVICE_URL=http://hosped-users:8080
QUARTO_SERVICE_URL=http://hosped-quarto:8080
RESERVA_SERVICE_URL=http://reserva-service:8080
PAGAMENTO_SERVICE_URL=http://hosped-pagamento:8080
PAYMENT_CONFIRMATION_BASE_URL=http://localhost:8080

# Local database names and credentials
RESERVA_DB_NAME=reserva_db
RESERVA_DB_USER=reserva_user
RESERVA_DB_PASSWORD=reserva_pass
QUARTO_DB_NAME=hosped_quartos
QUARTO_DB_USER=quartos_user
QUARTO_DB_PASSWORD=quartos_pass
USERS_DB_NAME=hosped_users
USERS_DB_USER=users_user
USERS_DB_PASSWORD=users_pass
PAGAMENTO_DB_NAME=hosped_pagamentos
PAGAMENTO_DB_USER=pagamentos_user
PAGAMENTO_DB_PASSWORD=pagamentos_pass

# RabbitMQ local
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Pagamento email integration - keep disabled unless SMTP is configured
PAGAMENTO_EMAIL_ENABLED=false
PAGAMENTO_EXPIRACAO_HORAS=8
PAGAMENTO_EXPIRACAO_VERIFICACAO_MS=60000
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEBUG=false

# Grafana local
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# External observability placeholders
PROMETHEUS_EXTERNAL_URL=https://hotel-prometheus-dev.onrender.com
GRAFANA_EXTERNAL_URL=https://hotel-grafana-dev.onrender.com
PROMETHEUS_DATASOURCE_URL=https://hotel-prometheus-dev.onrender.com
GF_SERVER_HTTP_PORT=10000

# GitHub Actions / Docker Hub - configure as GitHub secrets or vars, not in code
DOCKERHUB_USERNAME=your-dockerhub-user
DOCKERHUB_TOKEN=your-dockerhub-token
DOCKERHUB_NAMESPACE=your-dockerhub-namespace

# Sonar - configure in GitHub
SONAR_TOKEN=your-sonar-token
SONAR_HOST_URL=https://sonarcloud.io
SONAR_ORGANIZATION=your-sonar-organization
SONAR_PROJECT_KEY_HOSPED_USERS=hotel-hosped-users
SONAR_PROJECT_KEY_HOSPED_QUARTO=hotel-hosped-quarto
SONAR_PROJECT_KEY_HOSPED_PAGAMENTO=hotel-hosped-pagamento
SONAR_PROJECT_KEY_RESERVA_SERVICE=hotel-reserva-service
SONAR_PROJECT_KEY_HOSPED_GATEWAY=hotel-hosped-gateway

# Render deploy hooks - configure in GitHub secrets
RENDER_DEPLOY_HOOK_HOSPED_USERS_DEV=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_USERS_HOMOL=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_QUARTO_DEV=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_QUARTO_HOMOL=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_PAGAMENTO_DEV=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_PAGAMENTO_HOMOL=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_RESERVA_SERVICE_DEV=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_RESERVA_SERVICE_HOMOL=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_GATEWAY_DEV=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_HOSPED_GATEWAY_HOMOL=https://api.render.com/deploy/srv-xxx?key=xxx

# Render runtime placeholders
DATABASE_URL_DEV=postgresql://user:password@host:5432/database
DATABASE_URL_HOMOL=postgresql://user:password@host:5432/database
RABBITMQ_URL_DEV=amqp://user:password@host:5672
RABBITMQ_URL_HOMOL=amqp://user:password@host:5672
